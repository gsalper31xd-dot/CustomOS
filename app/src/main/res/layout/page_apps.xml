<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <EditText android:id="@+id/searchBox"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Uygulama ara..."
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:background="@drawable/search_bg"
            android:layout_margin="16dp"
            android:visibility="gone"/>

        <!-- ViewPager2 buraya eklenir programatik olarak -->

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="16dp">

        <LinearLayout android:id="@+id/dock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/dock_bg"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:padding="10dp"
            android:gravity="center"/>

    </LinearLayout>

</FrameLayout>
